{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/hook_check_protected_path.py"
          },
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/hook_check_delegated_write.py"
          },
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/hook_check_state_write.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/hook_check_commit_agent.py"
          },
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/hook_check_advance_actor.py"
          }
        ]
      },
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/hook_check_subagent_launch.py"
          },
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/hook_log_agent.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/hook_enforce_advance.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/hook_continue_flow.py"
          }
        ]
      }
    ]
  }
}
